# TradingView MCP

# Telegram morning brief
TELEGRAM_BOT_TOKEN=
# Comma-separated list works for private chat + morning brief group.
TELEGRAM_MORNING_CHAT_IDS=

# Telegram instant alerts
TELEGRAM_ALERT_CHAT_IDS=

# Require the active TradingView chart to contain these studies before automation runs
TV_REQUIRED_STUDIES=AI VP Reader - Full Bias Levels 10.1,Session Volume Profile,Absorption Bubbles

# If the active chart does not match, try switching back to this layout first
TV_RECOVERY_LAYOUT=AI VP盯盤＋訊號版面

# Delay between symbols when scanning the morning brief watchlist, in ms
TV_MORNING_SYMBOL_SWITCH_DELAY_MS=20000

# Delay between symbols when scanning the watcher watchlist, in ms
TV_WATCHER_SYMBOL_SWITCH_DELAY_MS=0

# Optional: point the CLI/scripts at a specific rules file
# TV_RULES_PATH=./rules.json
